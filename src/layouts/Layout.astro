---
import '../styles/global.css';
import MobileMenu from '../components/MobileMenu';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navLinks = [
  { label: t('nav.home'), href: `/${lang}` },
  { label: t('nav.about'), href: `/${lang}/about` },
  { label: t('nav.projects'), href: `/${lang}/projects` },
  // { label: t('nav.chat'), href: `/${lang}/chat` },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Aurélio Kanashiro — Backend Software Engineer" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title} — Aurélio Kanashiro</title>
  </head>
  <body class="bg-[#0a0a0a] text-[#e8e8e8] min-h-screen">

    <nav class="fixed top-0 left-0 right-0 z-50 px-6 md:px-8 py-4 flex justify-between items-center border-b border-white/5 backdrop-blur-sm bg-[#0a0a0a]/80">
      <a href={`/${lang}`} class="font-display text-lg font-bold tracking-tight hover:text-[#00ff88] transition-colors z-50">
        AK<span class="text-[#00ff88]">.</span>
      </a>

      <!-- desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a href={link.href} class="font-mono text-sm text-white/60 hover:text-white transition-colors">
            {link.label}
          </a>
        ))}
        <a href=`/aureliokanashiro_resume${lang === 'pt' ? "" : '_en'}.pdf` download class="font-mono text-sm px-4 py-2 border border-[#00ff88]/40 text-[#00ff88] hover:bg-[#00ff88] hover:text-black transition-all duration-200">
          {t('nav.resume')}
        </a>
        <div class="flex gap-2 ml-2">
          <a href={`/en${currentPath.substring(3)}`} class={`font-mono text-xs px-2 py-1 transition-colors ${lang === 'en' ? 'bg-[#00ff88] text-black' : 'text-white/40 hover:text-white'}`}>EN</a>
          <a href={`/pt${currentPath.substring(3)}`} class={`font-mono text-xs px-2 py-1 transition-colors ${lang === 'pt' ? 'bg-[#00ff88] text-black' : 'text-white/40 hover:text-white'}`}>PT</a>
        </div>
      </div>

      <!-- mobile nav -->
      <MobileMenu
        client:load
        lang={lang}
        links={navLinks}
        resumeLabel={t('nav.resume')}
        currentPath={currentPath}
      />
    </nav>

    <main class="pt-24">
      <slot />
    </main>

    <footer class="px-6 md:px-8 py-8 mt-20 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <span class="font-mono text-xs text-white/30">© {new Date().getFullYear()} Aurélio Kanashiro. {t('footer.rights')}</span>
      <div class="flex gap-6">
        <a href="https://github.com/aureliok" target="_blank" class="font-mono text-xs text-white/30 hover:text-white transition-colors">GitHub</a>
        <a href="https://www.linkedin.com/in/aurelio-k-kanashiro/" target="_blank" class="font-mono text-xs text-white/30 hover:text-white transition-colors">LinkedIn</a>
      </div>
    </footer>

  </body>
</html>