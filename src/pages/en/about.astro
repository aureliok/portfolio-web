---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');

const skills = {
  'Backend': ['TypeScript', 'NestJS', 'Python', 'FastAPI', 'C#', '.NET'],
  'Data & AI': ['Machine Learning', 'Data Science', 'Statistics', 'Pandas', 'Scikit-learn'],
  'Infrastructure': ['PostgreSQL', 'Redis', 'Docker', 'AWS'],
};

const education = [
  {
    degree: 'Specialization Course in Complex Data Mining',
    institution: 'UNICAMP - Universidade Estadual de Campinas',
    period: 'Jun 2020 — Dec 2020',
    description: 'Extension course in Complex Data Mining covering big data management, data visualization, business intelligence and predictive modeling using modern machine learning methods.',
  },
  {
    degree: 'Bachelor\'s in Statistics',
    institution: 'USP - Universidade de São Paulo',
    period: '2012 — 2018',
    description: 'Focus on statistical modeling, probability theory, statistical inference and data analysis.',
  },
];

const experience = [
  {
    role: 'Software Engineer',
    company: 'Gabriel',
    period: 'Jul 2024 - Present',
    description: 'Building data-driven backend services using TypeScript and NestJS.',
  },
  {
    role: 'Data Scientist',
    company: 'Amaris',
    period: 'Mar 2023 - Feb 2024',
    description: 'Conducted research and experiments with LLM and RAG applications across various business domains of a large telecommunications company.',
  },
  {
    role: 'Data Scientist',
    company: 'Coteminas',
    period: 'Feb 2022 - Feb 2023',
    description: 'Developed machine learning and deep learning models using unstructured data for a sleep monitoring product.',
  },
  {
    role: 'Data Scientist',
    company: 'Itaú',
    period: 'Apr 2020 - Aug 2021',
    description: 'Built text mining tools to extract information from PDF documents related to investment funds, enabling automation and reducing operational risk.',
  },
  {
    role: 'Data Scientist',
    company: 'Marketdata',
    period: 'Feb 2018 - Mar 2020',
    description: 'Responsible for developing statistical analyses and models focused on marketing.',
  },
];
---

<Layout title="About">
  <section style="padding-top: 2rem; padding-bottom: 5rem;">
    <div style="max-width: 1100px; margin: 0 auto; padding: 0 2.5rem;">

    <!-- header -->
    <div class="mb-16 animate-1">
      <div class="w-16 h-px bg-[#00ff88] mb-8"></div>
      <h1 class="font-display text-5xl md:text-6xl font-bold tracking-tight mb-6">
        {t('about.title')}
      </h1>
    </div>

    <!-- bio -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 mb-20 animate-1">
      <div class="lg:col-span-3 flex flex-col gap-6">
        <p class="font-mono text-sm text-white/60 leading-relaxed">{t('about.bio_1')}</p>
        <p class="font-mono text-sm text-white/60 leading-relaxed">{t('about.bio_2')}</p>
        <p class="font-mono text-sm text-white/60 leading-relaxed">{t('about.bio_3')}</p>
        <div class="flex gap-4 mt-4">
          <a href="https://github.com/aureliok" target="_blank" class="font-mono text-xs px-4 py-2 border border-white/20 text-white/50 hover:border-[#00ff88] hover:text-[#00ff88] transition-all duration-200">
            GitHub →
          </a>
          <a href="https://www.linkedin.com/in/aurelio-k-kanashiro/" target="_blank" class="font-mono text-xs px-4 py-2 border border-white/20 text-white/50 hover:border-[#00ff88] hover:text-[#00ff88] transition-all duration-200">
            LinkedIn →
          </a>
        </div>
      </div>

      <!-- skills -->
      <div class="lg:col-span-2 flex flex-col gap-8">
        <h2 class="font-display text-xl font-bold text-[#00ff88]">{t('about.skills_title')}</h2>
        {Object.entries(skills).map(([category, items]) => (
          <div>
            <p class="font-mono text-xs text-white/30 uppercase tracking-widest mb-3">{category}</p>
            <div class="flex flex-wrap gap-2">
              {items.map(skill => (
                <span class="font-mono text-xs px-3 py-1 border border-white/10 text-white/50 hover:border-[#00ff88]/50 hover:text-[#00ff88] transition-all duration-200 cursor-default">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- education -->
    <div class="section-gap">
      <div class="w-16 h-px bg-[#00ff88] mb-8 animate-1"></div>
      <h2 class="font-display text-3xl font-bold mb-12 animate-1">Education</h2>
      <div class="flex flex-col gap-6 animate-1">
        {education.map((item) => (
          <div class="flex flex-col gap-2 border-l-2 border-white/10 pl-6 hover:border-[#00ff88] transition-colors duration-300">
            <p class="font-mono text-xs text-white/30">{item.period}</p>
            <h3 class="font-display text-xl font-bold">{item.degree}</h3>
            <p class="font-mono text-sm text-[#00ff88] mb-1">{item.institution}</p>
            <p class="font-mono text-sm text-white/50 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- experience -->
    <div class="section-gap">
      <div class="w-16 h-px bg-[#00ff88] mb-8 animate-1"></div>
      <h2 class="font-display text-3xl font-bold mb-12 animate-1">Experience</h2>
      <div class="flex flex-col gap-6 animate-1">
        {experience.map((item) => (
          <div class="flex flex-col gap-2 border-l-2 border-white/10 pl-6 hover:border-[#00ff88] transition-colors duration-300">
            <p class="font-mono text-xs text-white/30">{item.period}</p>
            <h3 class="font-display text-xl font-bold">{item.role}</h3>
            <p class="font-mono text-sm text-[#00ff88] mb-1">{item.company}</p>
            <p class="font-mono text-sm text-white/50 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>

    </div>
  </section>
</Layout>

<style>
  .animate-1 {
    animation: fadeUp 0.8s ease forwards;
    opacity: 0;
  }

  .animate-2 {
    animation: fadeUp 0.8s ease forwards;
    animation-delay: 0.15s;
    opacity: 0;
  }

  .animate-3 {
    animation: fadeUp 0.8s ease forwards;
    animation-delay: 0.3s;
    opacity: 0;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>